<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Login_Page_App</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Login_Page_App.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Login_Page_App</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Login_Page_App - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        (function () {
            const userId = '@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value';
            if (!userId) return;

            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/notificationHub")
                .withAutomaticReconnect()
                .build();

            async function startConnection() {
                try {
                    await connection.start();
                    await connection.invoke("JoinUserGroup", userId);
                    console.log("SignalR connected");
                } catch (err) {
                    console.error("SignalR connection error:", err);
                    setTimeout(startConnection, 5000);
                }
            }

            connection.on("ReceiveLogoutWarning", function (secondsRemaining) {
                console.log("Logout warning: " + secondsRemaining + " seconds remaining");
                if (confirm("Your session will expire in " + secondsRemaining + " seconds. Do you want to extend your session?")) {
                    fetch('/Account/ExtendSession', { method: 'POST', credentials: 'same-origin' })
                        .then(r => r.json())
                        .then(data => {
                            if (data && data.expiry) {
                                document.cookie = 'AuthExpiry=' + encodeURIComponent(data.expiry) + '; path=/;';
                            }
                        })
                        .catch(() => {
                            alert('Could not extend session. Please log in again.');
                        });
                }
            });

            connection.on("ReceiveSessionExpired", function () {
                console.log("Session expired");
                document.cookie = 'AuthExpiry=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
                alert('Your session has expired. Please log in again.');
                window.location.href = '/Identity/Account/Login';
            });

            startConnection();
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
